{
    "name": "pepperfm/flashboard",
    "description": "Backend-driven Laravel admin runtime package for internal panels.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "laravel",
        "admin",
        "dashboard",
        "backoffice",
        "package"
    ],
    "autoload": {
        "psr-4": {
            "Pepperfm\\Flashboard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pepperfm\\Flashboard\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "PepperFM",
            "email": "Damon3453@yandex.ru"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/config": "^13",
        "illuminate/console": "^13",
        "illuminate/contracts": "^13",
        "illuminate/database": "^13",
        "illuminate/events": "^13",
        "illuminate/http": "^13",
        "illuminate/pagination": "^13",
        "illuminate/routing": "^13",
        "illuminate/support": "^13",
        "inertiajs/inertia-laravel": "^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pepperfm\\Flashboard\\Integration\\Laravel\\FlashboardServiceProvider"
            ]
        }
    },
    "prefer-stable": true
}
